{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "{{PROJECT_NAME}}",
    "description": "Design tokens generated by Design System Generator",
    "version": "1.0.0",
    "generated": "{{TIMESTAMP}}",
    "brand-color": "{{BRAND_COLOR}}"
  },

  "color": {
    "$type": "color",

    "primary": {
      "50":  { "$value": "oklch(97% {{C_50}} {{HUE}})" },
      "100": { "$value": "oklch(95% {{C_100}} {{HUE}})" },
      "200": { "$value": "oklch(90% {{C_200}} {{HUE}})" },
      "300": { "$value": "oklch(82% {{C_300}} {{HUE}})" },
      "400": { "$value": "oklch(71% {{C_400}} {{HUE}})" },
      "500": { "$value": "oklch(62% {{C_500}} {{HUE}})" },
      "600": { "$value": "oklch(55% {{C_600}} {{HUE}})" },
      "700": { "$value": "oklch(47% {{C_700}} {{HUE}})" },
      "800": { "$value": "oklch(37% {{C_800}} {{HUE}})" },
      "900": { "$value": "oklch(27% {{C_900}} {{HUE}})" },
      "950": { "$value": "oklch(18% {{C_950}} {{HUE}})" }
    },

    "neutral": {
      "50":  { "$value": "oklch(98% 0.015 {{HUE}})" },
      "100": { "$value": "oklch(96% 0.015 {{HUE}})" },
      "200": { "$value": "oklch(91% 0.012 {{HUE}})" },
      "300": { "$value": "oklch(83% 0.012 {{HUE}})" },
      "400": { "$value": "oklch(71% 0.010 {{HUE}})" },
      "500": { "$value": "oklch(55% 0.010 {{HUE}})" },
      "600": { "$value": "oklch(45% 0.010 {{HUE}})" },
      "700": { "$value": "oklch(37% 0.012 {{HUE}})" },
      "800": { "$value": "oklch(27% 0.012 {{HUE}})" },
      "900": { "$value": "oklch(20% 0.015 {{HUE}})" },
      "950": { "$value": "oklch(13% 0.015 {{HUE}})" }
    },

    "success": {
      "light":    { "$value": "oklch(92% 0.06 145)" },
      "default":  { "$value": "oklch(65% 0.19 145)" },
      "dark":     { "$value": "oklch(45% 0.15 145)" },
      "contrast": { "$value": "oklch(99% 0.01 145)" },
      "subtle":   { "$value": "oklch(97% 0.03 145)" }
    },

    "warning": {
      "light":    { "$value": "oklch(93% 0.06 85)" },
      "default":  { "$value": "oklch(78% 0.17 85)" },
      "dark":     { "$value": "oklch(50% 0.13 85)" },
      "contrast": { "$value": "oklch(20% 0.02 85)" },
      "subtle":   { "$value": "oklch(97% 0.04 85)" }
    },

    "error": {
      "light":    { "$value": "oklch(90% 0.06 25)" },
      "default":  { "$value": "oklch(63% 0.24 25)" },
      "dark":     { "$value": "oklch(45% 0.18 25)" },
      "contrast": { "$value": "oklch(99% 0.01 25)" },
      "subtle":   { "$value": "oklch(97% 0.03 25)" }
    },

    "info": {
      "light":    { "$value": "oklch(92% 0.05 235)" },
      "default":  { "$value": "oklch(62% 0.18 235)" },
      "dark":     { "$value": "oklch(45% 0.14 235)" },
      "contrast": { "$value": "oklch(99% 0.01 235)" },
      "subtle":   { "$value": "oklch(97% 0.03 235)" }
    }
  },

  "font": {
    "family": {
      "sans":  { "$value": "{{FONT_FAMILY}}", "$type": "fontFamily" },
      "serif": { "$value": "'Noto Serif', Georgia, serif", "$type": "fontFamily" },
      "mono":  { "$value": "'JetBrains Mono', 'Fira Code', ui-monospace, monospace", "$type": "fontFamily" }
    },
    "size": {
      "$type": "dimension",
      "xs":   { "$value": "0.64rem" },
      "sm":   { "$value": "0.80rem" },
      "base": { "$value": "1rem" },
      "md":   { "$value": "1.25rem" },
      "lg":   { "$value": "1.563rem" },
      "xl":   { "$value": "1.953rem" },
      "2xl":  { "$value": "2.441rem" },
      "3xl":  { "$value": "3.052rem" },
      "4xl":  { "$value": "3.815rem" }
    },
    "weight": {
      "$type": "number",
      "light":     { "$value": 300 },
      "regular":   { "$value": 400 },
      "medium":    { "$value": 500 },
      "semibold":  { "$value": 600 },
      "bold":      { "$value": 700 },
      "extrabold": { "$value": 800 }
    },
    "lineHeight": {
      "$type": "number",
      "none":    { "$value": 1 },
      "tight":   { "$value": 1.25 },
      "snug":    { "$value": 1.375 },
      "normal":  { "$value": 1.5 },
      "relaxed": { "$value": 1.625 },
      "loose":   { "$value": 2 }
    }
  },

  "spacing": {
    "$type": "dimension",
    "0":    { "$value": "0" },
    "px":   { "$value": "1px" },
    "0.5":  { "$value": "0.125rem" },
    "1":    { "$value": "0.25rem" },
    "1.5":  { "$value": "0.375rem" },
    "2":    { "$value": "0.5rem" },
    "2.5":  { "$value": "0.625rem" },
    "3":    { "$value": "0.75rem" },
    "4":    { "$value": "1rem" },
    "5":    { "$value": "1.25rem" },
    "6":    { "$value": "1.5rem" },
    "8":    { "$value": "2rem" },
    "10":   { "$value": "2.5rem" },
    "12":   { "$value": "3rem" },
    "16":   { "$value": "4rem" },
    "20":   { "$value": "5rem" },
    "24":   { "$value": "6rem" },
    "32":   { "$value": "8rem" }
  },

  "borderRadius": {
    "$type": "dimension",
    "none": { "$value": "0px" },
    "sm":   { "$value": "4px" },
    "md":   { "$value": "{{RADIUS_MD}}" },
    "lg":   { "$value": "12px" },
    "xl":   { "$value": "16px" },
    "2xl":  { "$value": "24px" },
    "full": { "$value": "9999px" }
  },

  "shadow": {
    "sm":  { "$value": "0 1px 2px oklch(0% 0 0 / 0.05)", "$type": "shadow" },
    "md":  { "$value": "0 2px 4px oklch(0% 0 0 / 0.05), 0 4px 8px oklch(0% 0 0 / 0.10)", "$type": "shadow" },
    "lg":  { "$value": "0 4px 8px oklch(0% 0 0 / 0.04), 0 8px 16px oklch(0% 0 0 / 0.08), 0 16px 32px oklch(0% 0 0 / 0.12)", "$type": "shadow" },
    "xl":  { "$value": "0 8px 16px oklch(0% 0 0 / 0.04), 0 16px 32px oklch(0% 0 0 / 0.08), 0 24px 48px oklch(0% 0 0 / 0.16)", "$type": "shadow" }
  },

  "zIndex": {
    "$type": "number",
    "behind":   { "$value": -1 },
    "base":     { "$value": 0 },
    "raised":   { "$value": 1 },
    "dropdown": { "$value": 10 },
    "sticky":   { "$value": 20 },
    "overlay":  { "$value": 30 },
    "modal":    { "$value": 40 },
    "popover":  { "$value": 50 },
    "toast":    { "$value": 60 }
  },

  "transition": {
    "fast":   { "$value": "100ms ease-out", "$type": "duration" },
    "normal": { "$value": "200ms ease-in-out", "$type": "duration" },
    "slow":   { "$value": "350ms ease-in-out", "$type": "duration" }
  }
}
