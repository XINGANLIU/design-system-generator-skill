/* ============================================
   PRIMITIVE TOKENS
   Base values — do not use directly in components.
   ============================================ */

:root {
  /* --- Primary Palette --- */
  --color-primary-50:  oklch(97% {{C_50}} {{HUE}});
  --color-primary-100: oklch(95% {{C_100}} {{HUE}});
  --color-primary-200: oklch(90% {{C_200}} {{HUE}});
  --color-primary-300: oklch(82% {{C_300}} {{HUE}});
  --color-primary-400: oklch(71% {{C_400}} {{HUE}});
  --color-primary-500: oklch(62% {{C_500}} {{HUE}});
  --color-primary-600: oklch(55% {{C_600}} {{HUE}});
  --color-primary-700: oklch(47% {{C_700}} {{HUE}});
  --color-primary-800: oklch(37% {{C_800}} {{HUE}});
  --color-primary-900: oklch(27% {{C_900}} {{HUE}});
  --color-primary-950: oklch(18% {{C_950}} {{HUE}});

  /* --- Neutral Palette (brand-tinted) --- */
  --color-neutral-50:  oklch(98% 0.015 {{HUE}});
  --color-neutral-100: oklch(96% 0.015 {{HUE}});
  --color-neutral-200: oklch(91% 0.012 {{HUE}});
  --color-neutral-300: oklch(83% 0.012 {{HUE}});
  --color-neutral-400: oklch(71% 0.010 {{HUE}});
  --color-neutral-500: oklch(55% 0.010 {{HUE}});
  --color-neutral-600: oklch(45% 0.010 {{HUE}});
  --color-neutral-700: oklch(37% 0.012 {{HUE}});
  --color-neutral-800: oklch(27% 0.012 {{HUE}});
  --color-neutral-900: oklch(20% 0.015 {{HUE}});
  --color-neutral-950: oklch(13% 0.015 {{HUE}});

  /* --- Semantic Colors --- */
  --color-success-light:    oklch(92% 0.06 145);
  --color-success:          oklch(65% 0.19 145);
  --color-success-dark:     oklch(45% 0.15 145);
  --color-success-contrast: oklch(99% 0.01 145);
  --color-success-subtle:   oklch(97% 0.03 145);

  --color-warning-light:    oklch(93% 0.06 85);
  --color-warning:          oklch(78% 0.17 85);
  --color-warning-dark:     oklch(50% 0.13 85);
  --color-warning-contrast: oklch(20% 0.02 85);
  --color-warning-subtle:   oklch(97% 0.04 85);

  --color-error-light:    oklch(90% 0.06 25);
  --color-error:          oklch(63% 0.24 25);
  --color-error-dark:     oklch(45% 0.18 25);
  --color-error-contrast: oklch(99% 0.01 25);
  --color-error-subtle:   oklch(97% 0.03 25);

  --color-info-light:    oklch(92% 0.05 235);
  --color-info:          oklch(62% 0.18 235);
  --color-info-dark:     oklch(45% 0.14 235);
  --color-info-contrast: oklch(99% 0.01 235);
  --color-info-subtle:   oklch(97% 0.03 235);

  /* --- Typography --- */
  --font-family-sans:  {{FONT_FAMILY}};
  --font-family-serif: 'Noto Serif', Georgia, 'Times New Roman', serif;
  --font-family-mono:  'JetBrains Mono', 'Fira Code', 'Cascadia Code', ui-monospace, monospace;

  --font-size-xs:   0.64rem;
  --font-size-sm:   0.80rem;
  --font-size-base: 1rem;
  --font-size-md:   1.25rem;
  --font-size-lg:   1.563rem;
  --font-size-xl:   1.953rem;
  --font-size-2xl:  2.441rem;
  --font-size-3xl:  3.052rem;
  --font-size-4xl:  3.815rem;

  --font-weight-light:     300;
  --font-weight-regular:   400;
  --font-weight-medium:    500;
  --font-weight-semibold:  600;
  --font-weight-bold:      700;
  --font-weight-extrabold: 800;

  --line-height-none:    1;
  --line-height-tight:   1.25;
  --line-height-snug:    1.375;
  --line-height-normal:  1.5;
  --line-height-relaxed: 1.625;
  --line-height-loose:   2;

  --letter-spacing-tighter: -0.05em;
  --letter-spacing-tight:   -0.025em;
  --letter-spacing-normal:  0em;
  --letter-spacing-wide:    0.025em;
  --letter-spacing-wider:   0.05em;
  --letter-spacing-widest:  0.1em;

  /* --- Spacing (4px base) --- */
  --spacing-0:    0;
  --spacing-px:   1px;
  --spacing-0\.5: 0.125rem;
  --spacing-1:    0.25rem;
  --spacing-1\.5: 0.375rem;
  --spacing-2:    0.5rem;
  --spacing-2\.5: 0.625rem;
  --spacing-3:    0.75rem;
  --spacing-4:    1rem;
  --spacing-5:    1.25rem;
  --spacing-6:    1.5rem;
  --spacing-8:    2rem;
  --spacing-10:   2.5rem;
  --spacing-12:   3rem;
  --spacing-16:   4rem;
  --spacing-20:   5rem;
  --spacing-24:   6rem;
  --spacing-32:   8rem;

  /* --- Border Radius --- */
  --radius-none: 0px;
  --radius-sm:   4px;
  --radius-md:   {{RADIUS_MD}};
  --radius-lg:   12px;
  --radius-xl:   16px;
  --radius-2xl:  24px;
  --radius-full: 9999px;

  /* --- Shadows --- */
  --shadow-sm: 0 1px 2px oklch(0% 0 0 / 0.05);
  --shadow-md: 0 2px 4px oklch(0% 0 0 / 0.05),
               0 4px 8px oklch(0% 0 0 / 0.10);
  --shadow-lg: 0 4px 8px oklch(0% 0 0 / 0.04),
               0 8px 16px oklch(0% 0 0 / 0.08),
               0 16px 32px oklch(0% 0 0 / 0.12);
  --shadow-xl: 0 8px 16px oklch(0% 0 0 / 0.04),
               0 16px 32px oklch(0% 0 0 / 0.08),
               0 24px 48px oklch(0% 0 0 / 0.16);

  /* --- Z-Index --- */
  --z-behind:   -1;
  --z-base:     0;
  --z-raised:   1;
  --z-dropdown: 10;
  --z-sticky:   20;
  --z-overlay:  30;
  --z-modal:    40;
  --z-popover:  50;
  --z-toast:    60;

  /* --- Transitions --- */
  --transition-fast:   100ms ease-out;
  --transition-normal: 200ms ease-in-out;
  --transition-slow:   350ms ease-in-out;
  --transition-spring: 500ms cubic-bezier(0.34, 1.56, 0.64, 1);
}


/* ============================================
   SEMANTIC TOKENS — Light/Dark Theme
   Use these in your components.
   ============================================ */

:root {
  color-scheme: light dark;

  /* Background */
  --color-bg-primary:    light-dark(var(--color-neutral-50),  var(--color-neutral-950));
  --color-bg-secondary:  light-dark(var(--color-neutral-100), var(--color-neutral-900));
  --color-bg-tertiary:   light-dark(var(--color-neutral-200), var(--color-neutral-800));
  --color-bg-inverse:    light-dark(var(--color-neutral-900), var(--color-neutral-50));

  /* Text */
  --color-text-primary:   light-dark(var(--color-neutral-900), var(--color-neutral-50));
  --color-text-secondary: light-dark(var(--color-neutral-600), var(--color-neutral-400));
  --color-text-muted:     light-dark(var(--color-neutral-400), var(--color-neutral-500));
  --color-text-inverse:   light-dark(var(--color-neutral-50),  var(--color-neutral-900));

  /* Interactive */
  --color-primary-surface: light-dark(var(--color-primary-50),  var(--color-primary-950));
  --color-primary-hover:   light-dark(var(--color-primary-700), var(--color-primary-400));
  --color-on-primary:      oklch(99% 0.005 {{HUE}});

  /* Border */
  --color-border:        light-dark(var(--color-neutral-200), var(--color-neutral-800));
  --color-border-strong: light-dark(var(--color-neutral-300), var(--color-neutral-700));
  --color-border-focus:  light-dark(var(--color-primary-500), var(--color-primary-400));
}


/* ============================================
   MANUAL THEME OVERRIDES
   For JavaScript-controlled theme toggle.
   ============================================ */

[data-theme="light"] {
  color-scheme: light;
  --color-bg-primary:     var(--color-neutral-50);
  --color-bg-secondary:   var(--color-neutral-100);
  --color-bg-tertiary:    var(--color-neutral-200);
  --color-bg-inverse:     var(--color-neutral-900);
  --color-text-primary:   var(--color-neutral-900);
  --color-text-secondary: var(--color-neutral-600);
  --color-text-muted:     var(--color-neutral-400);
  --color-text-inverse:   var(--color-neutral-50);
  --color-primary-surface: var(--color-primary-50);
  --color-primary-hover:  var(--color-primary-700);
  --color-border:         var(--color-neutral-200);
  --color-border-strong:  var(--color-neutral-300);
  --color-border-focus:   var(--color-primary-500);
}

[data-theme="dark"] {
  color-scheme: dark;
  --color-bg-primary:     var(--color-neutral-950);
  --color-bg-secondary:   var(--color-neutral-900);
  --color-bg-tertiary:    var(--color-neutral-800);
  --color-bg-inverse:     var(--color-neutral-50);
  --color-text-primary:   var(--color-neutral-50);
  --color-text-secondary: var(--color-neutral-400);
  --color-text-muted:     var(--color-neutral-500);
  --color-text-inverse:   var(--color-neutral-900);
  --color-primary-surface: var(--color-primary-950);
  --color-primary-hover:  var(--color-primary-400);
  --color-border:         var(--color-neutral-800);
  --color-border-strong:  var(--color-neutral-700);
  --color-border-focus:   var(--color-primary-400);

  /* Dark shadows need higher opacity */
  --shadow-sm: 0 1px 2px oklch(0% 0 0 / 0.15);
  --shadow-md: 0 2px 4px oklch(0% 0 0 / 0.15),
               0 4px 8px oklch(0% 0 0 / 0.25);
  --shadow-lg: 0 4px 8px oklch(0% 0 0 / 0.12),
               0 8px 16px oklch(0% 0 0 / 0.20),
               0 16px 32px oklch(0% 0 0 / 0.30);
}


/* ============================================
   MOTION PREFERENCES
   ============================================ */

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}
