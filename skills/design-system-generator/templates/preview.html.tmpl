<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <title>{{PROJECT_NAME}} — Design System Preview</title>
  <meta name="description" content="Visual preview of the {{PROJECT_NAME}} design system. Generated by Design System Generator.">
  <link rel="stylesheet" href="tokens.css">
  <link rel="stylesheet" href="components.css">
  <style>
    /* === Preview-specific styles === */
    .preview-section {
      padding: var(--spacing-12) var(--spacing-6);
      max-width: 72rem;
      margin: 0 auto;
    }

    .preview-section + .preview-section {
      border-top: 1px solid var(--color-border);
    }

    .section-title {
      font-size: var(--font-size-2xl);
      font-weight: var(--font-weight-bold);
      color: var(--color-text-primary);
      margin-bottom: var(--spacing-2);
      letter-spacing: var(--letter-spacing-tight);
    }

    .section-desc {
      font-size: var(--font-size-sm);
      color: var(--color-text-secondary);
      margin-bottom: var(--spacing-8);
      max-width: 40rem;
    }

    .subsection-title {
      font-size: var(--font-size-md);
      font-weight: var(--font-weight-semibold);
      color: var(--color-text-primary);
      margin-bottom: var(--spacing-4);
      margin-top: var(--spacing-8);
    }

    /* Color swatches */
    .swatch-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(5rem, 1fr));
      gap: var(--spacing-2);
      margin-bottom: var(--spacing-6);
    }

    .swatch {
      aspect-ratio: 1;
      border-radius: var(--radius-lg);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      padding: var(--spacing-2);
      font-size: 0.6rem;
      font-family: var(--font-family-mono);
      position: relative;
      border: 1px solid oklch(0% 0 0 / 0.06);
    }

    .swatch-label {
      text-align: center;
      line-height: 1.3;
      font-weight: var(--font-weight-medium);
    }

    /* Typography showcase */
    .type-sample {
      margin-bottom: var(--spacing-4);
    }

    .type-meta {
      font-size: var(--font-size-xs);
      color: var(--color-text-muted);
      font-family: var(--font-family-mono);
      margin-bottom: var(--spacing-1);
    }

    /* Component showcase */
    .component-row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--spacing-3);
      align-items: center;
      margin-bottom: var(--spacing-6);
    }

    .component-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      gap: var(--spacing-6);
      margin-bottom: var(--spacing-6);
    }

    /* Spacing visual */
    .spacing-demo {
      display: flex;
      align-items: flex-end;
      gap: var(--spacing-3);
      flex-wrap: wrap;
      margin-bottom: var(--spacing-6);
    }

    .spacing-block {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--spacing-1);
    }

    .spacing-visual {
      background: var(--color-primary-200);
      border-radius: var(--radius-sm);
      width: 2rem;
    }

    .spacing-label {
      font-size: 0.6rem;
      font-family: var(--font-family-mono);
      color: var(--color-text-muted);
    }

    /* Theme toggle */
    .theme-toggle {
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-full);
      padding: var(--spacing-1\.5) var(--spacing-3);
      cursor: pointer;
      font-size: var(--font-size-sm);
      color: var(--color-text-primary);
      transition: all var(--transition-fast);
      display: flex;
      align-items: center;
      gap: var(--spacing-2);
    }

    .theme-toggle:hover {
      background: var(--color-bg-tertiary);
    }

    /* Hero */
    .hero {
      text-align: center;
      padding: var(--spacing-20) var(--spacing-6);
      background: linear-gradient(
        180deg,
        var(--color-primary-surface) 0%,
        var(--color-bg-primary) 100%
      );
    }

    .hero-title {
      font-size: var(--font-size-4xl);
      font-weight: var(--font-weight-extrabold);
      letter-spacing: var(--letter-spacing-tighter);
      color: var(--color-text-primary);
      margin-bottom: var(--spacing-4);
    }

    .hero-subtitle {
      font-size: var(--font-size-md);
      color: var(--color-text-secondary);
      max-width: 36rem;
      margin: 0 auto;
    }

    /* Footer */
    .preview-footer {
      text-align: center;
      padding: var(--spacing-8) var(--spacing-6);
      font-size: var(--font-size-xs);
      color: var(--color-text-muted);
      border-top: 1px solid var(--color-border);
    }

    .preview-footer a {
      color: var(--color-primary-600);
      text-decoration: none;
    }
    .preview-footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar" id="navbar">
    <a href="#" class="navbar__brand">🎨 {{PROJECT_NAME}}</a>
    <ul class="navbar__nav">
      <li><a href="#colors" class="navbar__link is-active">Colors</a></li>
      <li><a href="#typography" class="navbar__link">Typography</a></li>
      <li><a href="#spacing" class="navbar__link">Spacing</a></li>
      <li><a href="#components" class="navbar__link">Components</a></li>
      <li>
        <button class="theme-toggle" data-theme-toggle id="theme-toggle">
          <span class="theme-icon">🌙</span>
          <span class="theme-label">Dark</span>
        </button>
      </li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero" id="hero">
    <h1 class="hero-title">{{PROJECT_NAME}}</h1>
    <p class="hero-subtitle">
      A complete design system generated from a single brand color.
      Explore colors, typography, spacing, and ready-to-use components below.
    </p>
  </section>

  <!-- COLORS -->
  <section class="preview-section" id="colors">
    <h2 class="section-title">Color Palette</h2>
    <p class="section-desc">All colors are generated in the OKLCH color space for perceptual uniformity and accessibility compliance.</p>

    <h3 class="subsection-title">Primary</h3>
    <div class="swatch-grid" id="primary-swatches">
      <!-- JS will populate -->
    </div>

    <h3 class="subsection-title">Neutral</h3>
    <div class="swatch-grid" id="neutral-swatches">
      <!-- JS will populate -->
    </div>

    <h3 class="subsection-title">Semantic</h3>
    <div class="swatch-grid" id="semantic-swatches">
      <!-- JS will populate -->
    </div>
  </section>

  <!-- TYPOGRAPHY -->
  <section class="preview-section" id="typography">
    <h2 class="section-title">Typography</h2>
    <p class="section-desc">Major Third scale (1.250 ratio). All sizes use rem units for accessibility.</p>

    <div id="type-showcase">
      <!-- JS will populate -->
    </div>
  </section>

  <!-- SPACING -->
  <section class="preview-section" id="spacing">
    <h2 class="section-title">Spacing</h2>
    <p class="section-desc">4px base unit with geometric progression. Consistent rhythm across all components.</p>

    <div class="spacing-demo" id="spacing-demo">
      <!-- JS will populate -->
    </div>
  </section>

  <!-- COMPONENTS -->
  <section class="preview-section" id="components">
    <h2 class="section-title">Components</h2>
    <p class="section-desc">Production-ready components using only design tokens. All components work in both Light and Dark themes.</p>

    <!-- Buttons -->
    <h3 class="subsection-title">Buttons</h3>
    <div class="component-row">
      <button class="btn btn--primary" id="btn-primary">Primary</button>
      <button class="btn btn--secondary" id="btn-secondary">Secondary</button>
      <button class="btn btn--ghost" id="btn-ghost">Ghost</button>
      <button class="btn btn--danger" id="btn-danger">Danger</button>
      <button class="btn btn--primary" disabled id="btn-disabled">Disabled</button>
    </div>
    <div class="component-row">
      <button class="btn btn--primary btn--sm" id="btn-sm">Small</button>
      <button class="btn btn--primary" id="btn-md">Default</button>
      <button class="btn btn--primary btn--lg" id="btn-lg">Large</button>
    </div>

    <!-- Badges -->
    <h3 class="subsection-title">Badges</h3>
    <div class="component-row">
      <span class="badge badge--primary" id="badge-primary">Primary</span>
      <span class="badge badge--success" id="badge-success">Success</span>
      <span class="badge badge--warning" id="badge-warning">Warning</span>
      <span class="badge badge--danger" id="badge-danger">Danger</span>
      <span class="badge badge--neutral" id="badge-neutral">Neutral</span>
    </div>

    <!-- Inputs -->
    <h3 class="subsection-title">Inputs</h3>
    <div class="component-grid">
      <div class="form-group">
        <label class="form-label" for="input-default">Default Input</label>
        <input class="input" type="text" id="input-default" placeholder="Type something...">
        <span class="form-helper">This is a helper text</span>
      </div>
      <div class="form-group">
        <label class="form-label" for="input-error">Error Input</label>
        <input class="input input--error" type="text" id="input-error" value="Invalid value" aria-invalid="true">
        <span class="form-error">This field has an error</span>
      </div>
      <div class="form-group">
        <label class="form-label" for="input-disabled">Disabled Input</label>
        <input class="input" type="text" id="input-disabled" disabled value="Disabled">
      </div>
    </div>

    <!-- Cards -->
    <h3 class="subsection-title">Cards</h3>
    <div class="component-grid">
      <div class="card card--elevated" id="card-elevated">
        <div class="card__header">
          <h4 class="card__title">Elevated Card</h4>
          <p class="card__desc">This card uses shadow for depth. Hover to see the lift effect.</p>
        </div>
        <div class="card__footer">
          <button class="btn btn--ghost btn--sm">Cancel</button>
          <button class="btn btn--primary btn--sm">Action</button>
        </div>
      </div>
      <div class="card card--outlined" id="card-outlined">
        <div class="card__header">
          <h4 class="card__title">Outlined Card</h4>
          <p class="card__desc">This card uses a border. Hover to see the border color change.</p>
        </div>
        <div class="card__footer">
          <button class="btn btn--ghost btn--sm">Cancel</button>
          <button class="btn btn--primary btn--sm">Action</button>
        </div>
      </div>
      <div class="card card--filled" id="card-filled">
        <div class="card__header">
          <h4 class="card__title">Filled Card</h4>
          <p class="card__desc">This card uses a subtle background fill for distinction.</p>
        </div>
        <div class="card__footer">
          <button class="btn btn--ghost btn--sm">Cancel</button>
          <button class="btn btn--primary btn--sm">Action</button>
        </div>
      </div>
    </div>

    <!-- Alerts -->
    <h3 class="subsection-title">Alerts</h3>
    <div class="flex flex-col gap-4">
      <div class="alert alert--info" id="alert-info">
        <span class="alert__icon">ℹ️</span>
        <div class="alert__body">
          <div class="alert__title">Information</div>
          A new version of the design system is available.
        </div>
      </div>
      <div class="alert alert--success" id="alert-success">
        <span class="alert__icon">✅</span>
        <div class="alert__body">
          <div class="alert__title">Success</div>
          Your design tokens have been saved successfully.
        </div>
      </div>
      <div class="alert alert--warning" id="alert-warning">
        <span class="alert__icon">⚠️</span>
        <div class="alert__body">
          <div class="alert__title">Warning</div>
          Some color combinations may not meet WCAG AA contrast.
        </div>
      </div>
      <div class="alert alert--danger" id="alert-danger">
        <span class="alert__icon">🚨</span>
        <div class="alert__body">
          <div class="alert__title">Error</div>
          Failed to generate color palette. Please check your input.
        </div>
      </div>
    </div>

    <!-- Avatars -->
    <h3 class="subsection-title">Avatars</h3>
    <div class="component-row">
      <div class="avatar avatar--sm" id="avatar-sm">S</div>
      <div class="avatar avatar--md" id="avatar-md">M</div>
      <div class="avatar avatar--lg" id="avatar-lg">L</div>
    </div>

    <!-- Skeleton -->
    <h3 class="subsection-title">Skeleton Loading</h3>
    <div style="max-width: 20rem;">
      <div class="flex gap-3 items-center" style="margin-bottom: var(--spacing-4)">
        <div class="skeleton skeleton--circle" style="width: 2.5rem; height: 2.5rem;"></div>
        <div class="flex-col gap-2" style="flex:1">
          <div class="skeleton skeleton--text" style="width: 60%;"></div>
          <div class="skeleton skeleton--text" style="width: 40%;"></div>
        </div>
      </div>
      <div class="skeleton skeleton--rect" style="margin-bottom: var(--spacing-3); border-radius: var(--radius-md);"></div>
      <div class="skeleton skeleton--text" style="width: 100%;"></div>
      <div class="skeleton skeleton--text" style="width: 80%;"></div>
      <div class="skeleton skeleton--text" style="width: 60%;"></div>
    </div>

    <!-- Tooltip -->
    <h3 class="subsection-title">Tooltips</h3>
    <div class="component-row">
      <span class="tooltip" id="tooltip-demo">
        <button class="btn btn--secondary">Hover me</button>
        <span class="tooltip__content">This is a tooltip</span>
      </span>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="preview-footer">
    <p>Generated by <a href="https://github.com/XINGANLIU/design-system-generator-skill" target="_blank">Design System Generator</a></p>
    <p style="margin-top: var(--spacing-1);">One color in → Full design system out 🎨</p>
  </footer>

  <script>
    // === Theme Toggle ===
    (function initThemeToggle() {
      const toggle = document.querySelector('[data-theme-toggle]');
      const root = document.documentElement;
      const icon = toggle.querySelector('.theme-icon');
      const label = toggle.querySelector('.theme-label');

      const saved = localStorage.getItem('ds-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = saved || (prefersDark ? 'dark' : 'light');
      applyTheme(theme);

      toggle.addEventListener('click', () => {
        const current = root.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        applyTheme(next);
        localStorage.setItem('ds-theme', next);
      });

      function applyTheme(t) {
        root.setAttribute('data-theme', t);
        if (t === 'dark') {
          icon.textContent = '☀️';
          label.textContent = 'Light';
        } else {
          icon.textContent = '🌙';
          label.textContent = 'Dark';
        }
      }
    })();

    // === Generate Color Swatches ===
    (function generateSwatches() {
      const steps = ['50','100','200','300','400','500','600','700','800','900','950'];
      const primaryGrid = document.getElementById('primary-swatches');
      const neutralGrid = document.getElementById('neutral-swatches');
      const semanticGrid = document.getElementById('semantic-swatches');

      steps.forEach(step => {
        primaryGrid.appendChild(createSwatch(`--color-primary-${step}`, step));
      });

      steps.forEach(step => {
        neutralGrid.appendChild(createSwatch(`--color-neutral-${step}`, step));
      });

      const semanticTokens = [
        '--color-success-light', '--color-success', '--color-success-dark',
        '--color-warning-light', '--color-warning', '--color-warning-dark',
        '--color-error-light', '--color-error', '--color-error-dark',
        '--color-info-light', '--color-info', '--color-info-dark',
      ];
      semanticTokens.forEach(token => {
        const label = token.replace('--color-', '');
        semanticGrid.appendChild(createSwatch(token, label));
      });

      function createSwatch(token, label) {
        const div = document.createElement('div');
        div.className = 'swatch';
        div.style.background = `var(${token})`;
        const lightness = parseInt(label) || 0;
        div.style.color = lightness > 400 || label.includes('dark') ? '#fff' : '#1a1a2e';
        div.innerHTML = `<span class="swatch-label">${label}</span>`;
        return div;
      }
    })();

    // === Generate Typography Showcase ===
    (function generateTypography() {
      const container = document.getElementById('type-showcase');
      const sizes = [
        { token: '--font-size-4xl', name: '4xl', rem: '3.815rem' },
        { token: '--font-size-3xl', name: '3xl', rem: '3.052rem' },
        { token: '--font-size-2xl', name: '2xl', rem: '2.441rem' },
        { token: '--font-size-xl',  name: 'xl',  rem: '1.953rem' },
        { token: '--font-size-lg',  name: 'lg',  rem: '1.563rem' },
        { token: '--font-size-md',  name: 'md',  rem: '1.25rem' },
        { token: '--font-size-base',name: 'base', rem: '1rem' },
        { token: '--font-size-sm',  name: 'sm',  rem: '0.80rem' },
        { token: '--font-size-xs',  name: 'xs',  rem: '0.64rem' },
      ];

      sizes.forEach(s => {
        const div = document.createElement('div');
        div.className = 'type-sample';
        div.innerHTML = `
          <div class="type-meta">${s.name} · ${s.rem}</div>
          <div style="font-size: var(${s.token}); font-weight: var(--font-weight-semibold); line-height: var(--line-height-tight);">
            The quick brown fox jumps over the lazy dog
          </div>
        `;
        container.appendChild(div);
      });
    })();

    // === Generate Spacing Demo ===
    (function generateSpacing() {
      const container = document.getElementById('spacing-demo');
      const spacings = [
        { name: '1', px: '4px' },
        { name: '2', px: '8px' },
        { name: '3', px: '12px' },
        { name: '4', px: '16px' },
        { name: '6', px: '24px' },
        { name: '8', px: '32px' },
        { name: '10', px: '40px' },
        { name: '12', px: '48px' },
        { name: '16', px: '64px' },
      ];

      spacings.forEach(s => {
        const block = document.createElement('div');
        block.className = 'spacing-block';
        block.innerHTML = `
          <div class="spacing-visual" style="height: ${s.px};"></div>
          <span class="spacing-label">${s.name}</span>
          <span class="spacing-label">${s.px}</span>
        `;
        container.appendChild(block);
      });
    })();
  </script>
</body>
</html>
